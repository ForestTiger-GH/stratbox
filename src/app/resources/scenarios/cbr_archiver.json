{
  "id": "cbr_archiver",
  "title": "Архиватор исходных файлов ЦБ",
  "description": "Скачивает исходные статистические файлы Банка России и сохраняет их через активный FileStore как ZIP-архив или папку файлов.",
  "group": "Банк России",
  "kind": "export",
  "tags": ["cbr", "archive"],
  "adapter": "app.scenarios.adapters.cbr_archiver:run",
  "enabled": true,
  "requires_workspace": true,
  "input_dir": "input/cbr_archiver",
  "output_dir": "output/cbr_archiver",
  "params": [
    {
      "name": "output_mode",
      "title": "Режим сохранения",
      "type": "select",
      "default": "zip",
      "options": ["zip", "files"],
      "description": "zip — один архив, files — отдельная папка с файлами."
    },
    {
      "name": "output_dir",
      "title": "Папка результата",
      "type": "text",
      "default": "output/cbr_archiver",
      "description": "Относительный путь внутри workspace root."
    },
    {
      "name": "replace_existing",
      "title": "Перезаписывать результат",
      "type": "bool",
      "default": true
    },
    {
      "name": "continue_on_error",
      "title": "Продолжать при ошибках скачивания",
      "type": "bool",
      "default": true
    }
  ],
  "links": [
    {
      "title": "Банк России",
      "url": "https://www.cbr.ru/"
    }
  ]
}
