{
  "contract_version": "1.0",
  "identity": {
    "world_id": "stratbox",
    "display_name": "Strategy Box",
    "version": "0.1.0",
    "vendor": "Strategy Box",
    "description": "Strategy Box desktop surface for AppDock-managed analytical work.",
    "display_category": "analytics_desktop"
  },
  "default_surface_id": "stratbox.desktop",
  "surfaces": [
    {
      "surface_id": "stratbox.desktop",
      "display_name": "Strategy Box",
      "surface_role": "interactive",
      "activation": {
        "kind": "python_module",
        "target": "app.platform.appdock.entry",
        "args": [],
        "cwd_policy": {
          "mode": "source_root"
        },
        "env_policy": {
          "mode": "appdock_activation"
        },
        "diagnostics": {
          "strategy": "flag",
          "flag": "--diagnose",
          "timeout_seconds": 30
        },
        "launch_mode": "foreground",
        "locality": "local",
        "platform_constraints": {
          "node_platforms": [
            "windows_desktop_node",
            "linux_desktop_node"
          ],
          "client_platforms": [
            "desktop"
          ]
        },
        "metadata": {
          "ui": "primary"
        }
      },
      "entry_view": "timeline",
      "declared_views": [
        "timeline",
        "operations",
        "artifacts",
        "workspace",
        "participants",
        "diagnostics",
        "domain"
      ],
      "compatible_modes": [
        "local",
        "attached"
      ],
      "required_capabilities": [
        "runtime.activate"
      ],
      "minimum_node_features": [
        "workspace_context",
        "health_snapshot"
      ],
      "supports_resume": true,
      "supports_artifacts": true,
      "supports_remote_attach": false,
      "supports_presence": true,
      "supports_delegated_jobs": false,
      "metadata": {
        "product": "Strategy Box",
        "ui_kind": "desktop_timeline_surface",
        "route_groups_visible_in_app": [
          "operations",
          "artifacts",
          "node",
          "diagnostics"
        ]
      }
    }
  ],
  "profiles": {
    "world_profile": "desktop_analytical_world",
    "capability_profiles": [
      "desktop_analytical_world"
    ],
    "publication_profiles": [],
    "supported_node_modes": [
      "local",
      "attached"
    ]
  },
  "capabilities": {
    "supports_remote_attach": false,
    "supports_delegated_jobs": false,
    "supports_artifacts": true,
    "supports_resume": true,
    "supports_presence": true
  },
  "requirements": {
    "required_capabilities": [
      "runtime.activate"
    ],
    "minimum_node_features": [
      "workspace_context",
      "health_snapshot"
    ],
    "compatible_modes": [
      "local",
      "attached"
    ]
  },
  "storage": {
    "requests": {
      "install_root_system_dir": {
        "enabled": true,
        "directory_name": "stratbox-system"
      }
    }
  },
  "metadata": {
    "description": "Strategy Box desktop app surface for AppDock world entry."
  }
}
