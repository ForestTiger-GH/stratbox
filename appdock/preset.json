{
  "contract_version": "1.0",
  "distribution_profile_ref": "profile.desktop_client",
  "product_identity": {
    "product_id": "stratbox.desktop",
    "display_name": "Strategy Box",
    "product_version": "0.1.0",
    "vendor": "Strategy Box",
    "channel": "default"
  },
  "source_policy": {
    "source_mode": "user_selected_managed_source",
    "allow_user_source_selection": true
  },
  "install_context": {
    "mode": "portable_local",
    "install_display_name": "Strategy Box",
    "allow_install_root_override": true,
    "bundle_root_policy": "inside_install_root",
    "data_root_policy": "inside_install_root",
    "show_advanced_options": false
  },
  "frontdoor": {
    "presentation_profile_id": "terminal_minimal",
    "requires_frontdoor_before_launch": true,
    "allow_frontdoor_skip_when_installed": true
  },
  "visibility_policy": {
    "show_source_step": true,
    "show_preview_step": true,
    "show_install_step": true,
    "show_review_step": true
  },
  "entry_behavior": {
    "profile_id": "direct_to_app",
    "launcher_visibility": "on_demand"
  },
  "branding": {
    "branding_mode": "default",
    "display_name_override": "Strategy Box"
  },
  "update_policy": {
    "mode": "auto_on_launch",
    "update_on_launch": true
  },
  "shortcut_policy": {
    "desktop_shortcut": false,
    "start_menu_shortcut": false,
    "shortcut_target": "entry_surface"
  },
  "feature_selection": {
    "enabled_features": [
      "desktop_surface",
      "resume",
      "artifacts",
      "presence"
    ],
    "disabled_features": [
      "remote_attach",
      "delegated_jobs"
    ],
    "visible_sectors": [
      "runtime",
      "artifacts",
      "workspace"
    ],
    "hidden_sectors": [
      "remote",
      "host"
    ]
  },
  "first_run": {
    "requires_frontdoor": true,
    "entry_behavior_profile_id": "direct_to_app",
    "allow_skip_after_completion": true
  },
  "metadata": {
    "product_kind": "desktop_analytics_app",
    "default_off_policy": true
  }
}
